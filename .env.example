DATABASE_URL=postgresql+asyncpg://rank:rank@db:5432/rank
ALEMBIC_DATABASE_URL=postgresql+psycopg://rank:rank@db:5432/rank
REDIS_URL=redis://redis:6379/0

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-please-at-least-32-chars-long-random

# Generate with: python -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
TELLER_TOKEN_ENC_KEY=base64-encoded-32-byte-key-replace-me==

# Teller (https://teller.io/dashboard)
TELLER_APP_ID=your_teller_app_id
TELLER_ENVIRONMENT=development
TELLER_CERT_PATH=/certs/certificate.pem
TELLER_KEY_PATH=/certs/private_key.pem

# JWT
JWT_ALG=HS256
JWT_TTL_HOURS=24
