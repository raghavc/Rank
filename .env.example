DATABASE_URL=postgresql+asyncpg://rank:rank@db:5432/rank
ALEMBIC_DATABASE_URL=postgresql+psycopg://rank:rank@db:5432/rank
REDIS_URL=redis://redis:6379/0

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-please-at-least-32-chars-long-random

# JWT (access tokens are short-lived; refresh tokens stored hashed in Postgres)
JWT_ALG=HS256
JWT_ISS=rank-api
JWT_AUD=rank-ios
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30

# Generate with: python -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
TELLER_TOKEN_ENC_KEY=base64-encoded-32-byte-key-replace-me==

# Teller (https://teller.io/dashboard)
TELLER_APP_ID=your_teller_app_id
TELLER_ENVIRONMENT=development
TELLER_CERT_PATH=/certs/certificate.pem
TELLER_KEY_PATH=/certs/private_key.pem

# PEM public key from Teller dashboard (Token Signing Key). When set, Connect uses a
# server-issued nonce and /bank/link verifies enrollment signatures.
# TELLER_CONNECT_SIGNING_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# CORS: leave empty for iOS-only APIs. Comma-separated origins if you add a web client.
# CORS_ORIGINS=

# Behind a reverse proxy / ALB, set allowed Host headers (comma-separated).
# TRUSTED_HOSTS=api.yourdomain.com

# Multi-instance rate limits: point SlowAPI at Redis (e.g. db 1).
# RATE_LIMIT_STORAGE_URI=redis://redis:6379/1
